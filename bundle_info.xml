<!--
ChimeraX bundle names must start with "ChimeraX-"
to avoid clashes with package names in pypi.python.org.
When uploaded to the ChimeraX toolshed, the bundle
will be displayed without the ChimeraX- prefix.
-->

<BundleInfo name="ChimeraX-ChopChopMF" version="1.2" package="chimerax.chopchop_mf" minSessionVersion="1" maxSessionVersion="1">
  
  <!-- Author and Contact Information -->
  <Author>Lukas W. Bauer, Ricarda Erhart ISTA Bioinformatics, Florian K. M. Schur</Author>
  <URL>https://lukasinscience.github.io/ChopChopMF/</URL>
  <Email>luki.bauer94@gmail.com</Email>
  
  <!-- Synopsis and Description -->
  <Synopsis>ChopChopMF: Multi-functional protein structure analyzation Plugin for ChimeraX</Synopsis>
  <Description>3D protein structures are crucial for understanding biological function, yet experimental determination is often slow and complex. Computational tools such as AlphaFold now provide rapid predictions, but analyzing and comparing these models to experimental data can be challenging. UCSF ChimeraX offers powerful visualization and analysis features, but its complexity limits accessibility for new users, and complicates workflows due a complicated syntax even for advanced users.ChopChopMF addresses this issue, by adding an intuitive graphical interface to ChimeraX. This interface enables both inexperienced and advanced users to quickly explore and analyze protein structures, by ChopChopMF tools covering topics as: Sequence alignments, AlphaMissense plots, Foldseek, PDBePisa plots and more.</Description>
  
  <!-- Categories for toolshed listing -->
  <Categories>
    <Category name="General"/>
  </Categories>
  
  <!-- Dependencies -->
  <Dependencies>
    <Dependency name="ChimeraX-Core" version="~=1.9"/>
    <Dependency name="ChimeraX-UI" version="~=1.0"/>
    <Dependency name="ChimeraX-Graphics" version=">=1.1"/>
    <Dependency name="ChimeraX-Atomic" version=">=1.1"/>
    <Dependency name="PyQt5" version=">=5.15.0"/>
    <Dependency name="pandas" version=">=1.0.0"/>
  </Dependencies>

  <!-- Non-Python files included in the package -->
  <DataFiles>
    <DataFile>icons/*.png</DataFile>
  </DataFiles>

  <!-- Toolbar Button Providers -->
  <Providers manager="toolbar">
      <Provider tab="ChopChopMF" section="Alignment"
                name="Sequence"
                icon="ChopAlignIcon.png"
                description="Initialize and launch the ChopChopMFalignment tool GUI."/>
      <Provider tab="ChopChopMF" section="Fetch PDB"
                name="AlphaMissense"
                icon="ChopGetMissense.png"
                description="Launch the ChopChopGetMissense tool."/>
      <Provider tab="ChopChopMF" section="Alignment"
                name="Missense"
                icon="ChopMissenseIcon.png"
                description="Launch the ChopMissense tool."/>
      <Provider tab="ChopChopMF" section="Modify Structure"
                name="Crop Structure"
                icon="crop.png"
                description="Launch the CropStructure tool."/>
      <Provider tab="ChopChopMF" section="Modify Structure"
                name="Duplicate Structure"
                icon="copyicon.png"
                description="Launch the DuplicateStructure tool."/>
      <Provider tab="ChopChopMF" section="Analyze Structure"
                name="PAE Analysis"
                icon="pae_icon.png"
                description="Launch the PAE Analysis tool."/>
      <Provider tab="ChopChopMF" section="Analyze Structure"
                name="PDBePISA"
                icon="pisa.png"
                description="Launch the PDBePISA tool."/>
      <Provider tab="ChopChopMF" section="Analyze Structure"
                name="Foldseek Analysis"
                icon="foldseeklogo.png"
                description="Launch the FoldseekAnalysis tool."/>
      <Provider tab="ChopChopMF" section="Undo"
                name="Undo"
                icon="ChopUndo.png"
                description="Undo the last action performed in the ChopChopMFalignment tool."/>
      <Provider tab="ChopChopMF" section="Fetch PDB"
                name="AlphaFold2"
                icon="AlphaFoldIconChop.png"
                description="Load and show the AlphaFold tool."/>

  </Providers>

  <!-- Tools menu registration (adds discoverability; names must match __init__.py) -->
  <Tools>
      <Tool name="Sequence" category="ChopChopMF/Alignment"/>
      <Tool name="AlphaMissense" category="ChopChopMF/Fetch PDB"/>
      <Tool name="Missense" category="ChopChopMF/Alignment"/>
      <Tool name="Crop Structure" category="ChopChopMF/Modify Structure"/>
      <Tool name="Duplicate Structure" category="ChopChopMF/Modify Structure"/>
      <Tool name="PAE Analysis" category="ChopChopMF/Analyze Structure"/>
      <Tool name="PDBePISA" category="ChopChopMF/Analyze Structure"/>
      <Tool name="Foldseek Analysis" category="ChopChopMF/Analyze Structure"/>
      <Tool name="AlphaFold2" category="ChopChopMF/Fetch PDB"/>
  </Tools>

  <!-- Installation Logging -->
  <Install>
    <Command>logger info "ChopChopMF-1.1"</Command>
  </Install>

  <!-- ChimeraX-specific classifiers -->
  <Classifiers>
    <PythonClassifier>Development Status :: 3 - Alpha</PythonClassifier>
    <PythonClassifier>License :: Freeware</PythonClassifier>
    <ChimeraXClassifier>ChimeraX :: Tool :: ChopChopMF :: Provides sequence alignment visualization tools</ChimeraXClassifier>
  </Classifiers>
</BundleInfo>



